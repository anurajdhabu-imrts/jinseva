# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Shree Jinalaya — monorepo .gitignore
#  (npm-workspaces frontend + FastAPI/Python backend)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ━━━ Node / JS dependencies ━━━
node_modules/
.pnpm-store/
.npm/
.yarn/

# ━━━ Builds / bundler output ━━━
dist/
build/
.next/
.cache/
.parcel-cache/
.vite/

# ━━━ Env / secrets (NEVER commit a real .env — only *.example is tracked) ━━━
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
*.pem
*.key
# keep example templates tracked
!.env.example
!**/.env.example

# ━━━ Python / FastAPI backend ━━━
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
# virtual environments (any name/location)
.venv/
venv/
env/
ENV/
.python-version
# tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
# local databases (if ever used)
*.sqlite3
*.db

# ━━━ Logs / temp ━━━
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
_server.log
_server.err

# ━━━ Editor / IDE ━━━
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ━━━ OS ━━━
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ━━━ Test / coverage ━━━
coverage/
.nyc_output/

# ━━━ Misc ━━━
*.tsbuildinfo
.eslintcache
graphify-out/
