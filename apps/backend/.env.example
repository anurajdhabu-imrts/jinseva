# ━━━ Server ━━━
ENV=development
PORT=5000
# Comma-separated list of allowed browser origins (the Vite dev server).
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ━━━ Database (PostgreSQL) ━━━
# Format: postgresql+psycopg://<user>:<password>@<host>:<port>/<db>
# Copy this file to `.env` and set your real credentials there (never commit .env).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/temple_local_db

# ━━━ Auth ━━━
JWT_SECRET=replace-with-a-strong-random-string
JWT_EXPIRES_MINUTES=10080

# ━━━ Seed (bootstrap admin — used by `python seed.py`) ━━━
SEED_ADMIN_NAME=Temple Admin
SEED_ADMIN_EMAIL=admin@jinalaya.org
SEED_ADMIN_PASSWORD=ChangeMe@123
